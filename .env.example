# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Twilio SMS (get free trial at twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+15551234567

# CareWatch config
ALERT_COOLDOWN_MINUTES=15        # Min minutes between same alert type
BASELINE_LEARNING_DAYS=7         # Days before baseline is considered reliable
FALL_RECOVERY_SECONDS=30         # Seconds on floor before fall alert triggers
NO_MOTION_DAY_MINUTES=120        # Minutes of daytime inactivity before alert
BREATHING_DEVIATION_THRESHOLD=0.25  # 25% deviation from baseline triggers alert

# Database
DATABASE_URL=postgresql://carewatch:carewatch@localhost:5432/carewatch

# Server
PORT=4000
JWT_SECRET=change-this-to-a-random-string

# ESP32 Bridge
ESP32_UDP_PORT=5005                # UDP port for direct ESP32 CSI frames
ESP32_BACKEND_URL=                 # Leave blank for auto (http://localhost:PORT/api/esp32/frame)
ESP32_DEFAULT_ROOM=default         # Default room name for ESP32 frames

# RuView Sensing Server (optional)
RUVIEW_WS_URL=ws://localhost:3001/ws/sensing
RUVIEW_REST_URL=http://localhost:3000
