{
  "name": "carewatch-dashboard",
  "version": "1.0.0",
  "description": "CareWatch — WiFi CSI elderly care monitoring",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "icons": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "date-fns": "^3.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "vite": "^5.1.4",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.carewatch.app",
    "productName": "CareWatch",
    "copyright": "Copyright © 2025 CareWatch",
    "asar": true,
    "icon": "electron/assets/icon-1024.png",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "electron/assets", "to": "assets" }
    ],
    "mac": {
      "category": "public.app-category.medical",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "icon": "electron/assets/icon-1024.png",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "notarize": false
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "electron/assets/icon-256.png"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Science"
    },
    "dmg": {
      "title": "CareWatch",
      "background": null,
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "eliomontes-prog",
      "repo": "carewatch"
    }
  }
}
